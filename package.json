{
  "name": "@ngx-pwa/local-storage",
  "version": "22.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "start:iframe": "ng serve iframe --port 8080",
    "build": "ng build lib && npm run schematics",
    "test": "npm run unit && npm run e2e",
    "unit": "npx playwright install && ng test lib --watch false",
    "unit:ci": "npx playwright install --with-deps && ng test lib --watch false",
    "e2e": "playwright install chromium && npm run e2e:demo && npm run e2e:interoperability",
    "e2e:demo": "playwright test --config playwright-demo.config.ts",
    "e2e:interoperability": "playwright test --config playwright-localforage.config.ts",
    "lint": "ng lint",
    "schematics": "tsc -p lib/tsconfig.schematics.json && copyfiles --up 1 lib/schematics/collection.json lib/schematics/migration.json lib/schematics/**/schema.json dist/lib",
    "release:patch": "VERSION=patch npm run release",
    "release:minor": "VERSION=minor npm run release",
    "release:major": "VERSION=major npm run release",
    "release": "if test $VERSION; then npm run build && cd lib && npm version $VERSION --no-git-tag-version && git add package.json && cd .. && git commit -m \"release\" && npm version $VERSION && git push; fi",
    "publish-release": "git push origin v$npm_package_version"
  },
  "private": true,
  "packageManager": "npm@11.6.3",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sinclair/typebox": "^0.34.49",
    "@vitest/browser-playwright": "^4.1.8",
    "angular-eslint": "^21.4.0",
    "angular-eslint-injection-context": "^1.6.0",
    "angular-eslint-zoneless": "^1.6.0",
    "better-typescript-lib": "~2.12.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "localforage": "^1.10.0",
    "ng-packagr": "^22.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.0.11"
  },
  "overrides": {
    "angular-eslint": {
      "@angular/cli": "$@angular/cli"
    }
  },
  "allowScripts": {
    "@parcel/watcher": false,
    "esbuild": false,
    "lmdb": false,
    "msgpackr-extract": false
  }
}